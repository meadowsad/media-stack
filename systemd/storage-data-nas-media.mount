[Unit]
Description=NAS Media NFS Mount
Requires=network-online.target
After=network-online.target
Before=docker.service

[Mount]
# Replace YOUR_NAS_IP and YOUR_NAS_SHARE_PATH with your actual values
What=YOUR_NAS_IP:YOUR_NAS_SHARE_PATH
Where=/storage/data/nas/media
Type=nfs
Options=rw,hard,nofail,_netdev,rsize=1048576,wsize=1048576,timeo=14,retrans=2,noexec,nosuid,nodev

[Install]
WantedBy=multi-user.target
